int noteDuration = 180; // ESP32 bisa memproses lebih cepat, kita buat tempo sedikit lebih pas

int totalNotes = sizeof(melody) / sizeof(int);
int currentNoteIndex = 0;
unsigned long lastNoteTime = 0;

