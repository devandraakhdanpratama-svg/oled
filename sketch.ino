// Pengaturan Visualizer (Equalizer)
const int numBars = 8;
int barWidth = 5;
int barSpacing = 2;
int visualizerStartX = 70;
int barHeights[numBars];
int targetHeights[numBars];

int headBangState = 0;

void setup() {
  // ESP32 menggunakan pin I2C default (SDA=21, SCL=22)
  Wire.begin(21, 22); 
  
  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) { 
    for(;;);
  }
  display.clearDisplay();
  
  // Inisialisasi Pin Buzzer
  pinMode(BUZZER_PIN, OUTPUT);
}

void loop() {
  unsigned long currentMillis = millis();

  // --- PEMUTAR MUSIK NON-BLOCKING ---
  if (currentMillis - lastNoteTime >= noteDuration) {
    noTone(BUZZER_PIN); 
    
    int noteFrequency = melody[currentNoteIndex];
    
    // Fungsi tone() pada core ESP32 di Wokwi bekerja sama seperti Arduino
    tone(BUZZER_PIN, noteFrequency, noteDuration - 20);
    
    lastNoteTime = currentMillis;
    headBangState = (headBangState + 1) % 2;

    // Mengatur lompatan visualizer berdasarkan nada
    for (int i = 0; i < numBars; i++) {
      targetHeights[i] = map(noteFrequency, 185, 494, 10, 56) + random(-5, 6);
    }

    currentNoteIndex = (currentNoteIndex + 1) % totalNotes;
  }

  // --- RE-RENDER GRAFIK OLED ---
  display.clearDisplay();

  // 1. Animasi Kepala Mengangguk
  if (headBangState == 0) {
    display.drawBitmap(5, 6, epd_bitmap_headphone1, 48, 48, SSD1306_WHITE);
  } else {
    display.drawBitmap(5, 10, epd_bitmap_headphone2, 48, 48, SSD1306_WHITE);
  }

  // 2. Animasi Audio Equalizer 
  for (int i = 0; i < numBars; i++) {
    // Kecepatan transisi naik turun batang dibuat lebih responsif pada ESP32
    if (barHeights[i] < targetHeights[i]) barHeights[i] += 5;
    if (barHeights[i] > targetHeights[i]) barHeights[i] -= 5;

    barHeights[i] = constrain(barHeights[i], 2, 58);

    int x = visualizerStartX + (i * (barWidth + barSpacing));
    display.fillRect(x, SCREEN_HEIGHT - barHeights[i], barWidth, barHeights[i], SSD1306_WHITE);
  }

  display.display();
  delay(8); // Delay kecil yang dioptimalkan untuk FPS ESP32
}